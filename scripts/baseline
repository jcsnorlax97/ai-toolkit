#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
BASELINES_DIR="$ROOT_DIR/baselines"
COMMAND_NAME="${BASELINE_COMMAND_NAME:-baseline}"

COMMAND="${1:-list}"
if [[ $# -gt 0 ]]; then
  shift
fi

PACK=""
TARGET_REPO="$(pwd -P)"
TARGET_REPO_PROVIDED=0
TOOLS="codex,claude"
DRY_RUN=0
CREATE_MISSING=0
TOOLS_PROVIDED=0

usage() {
  cat <<USAGE
Usage:
  $COMMAND_NAME list
  $COMMAND_NAME show [--pack <pack>|all]
  $COMMAND_NAME apply --pack <pack>|all --tools codex,claude,copilot|all [--target-repo <path>] [--dry-run] [--create-missing]
  $COMMAND_NAME remove --pack <pack>|all --tools codex,claude,copilot|all [--target-repo <path>] [--dry-run]
  $COMMAND_NAME verify [--pack <pack>|all] [--tools codex,claude,copilot|all] [--target-repo <path>]

When exactly one pack exists, --pack may be omitted. Verify defaults to all
packs. The value "all" expands to every pack or every supported tool.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pack|-Pack)
      PACK="$2"
      shift 2
      ;;
    --target-repo|-TargetRepo)
      TARGET_REPO="$2"
      TARGET_REPO_PROVIDED=1
      shift 2
      ;;
    --tools|-Tools)
      TOOLS="$2"
      TOOLS_PROVIDED=1
      shift 2
      ;;
    --dry-run|-DryRun)
      DRY_RUN=1
      shift
      ;;
    --create-missing|-CreateMissing)
      CREATE_MISSING=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

pack_root() {
  printf '%s/%s' "$BASELINES_DIR" "$1"
}

pack_names() {
  find "$BASELINES_DIR" -mindepth 1 -maxdepth 1 -type d | sort | while read -r dir; do
    [[ -f "$dir/pack.json" ]] || continue
    basename "$dir"
  done
}

require_pack() {
  local pack="$1"
  if [[ ! -f "$(pack_root "$pack")/pack.json" ]]; then
    echo "Unknown portable baseline pack: $pack" >&2
    exit 1
  fi
}

resolve_packs() {
  local names=()
  local name

  if [[ "$COMMAND" == "verify" && -z "$PACK" ]]; then
    PACK="all"
  fi

  if [[ "$PACK" == "all" ]]; then
    while IFS= read -r name; do
      names+=("$name")
    done < <(pack_names)
    if [[ "${#names[@]}" -eq 0 ]]; then
      echo "No portable baseline packs found in: $BASELINES_DIR" >&2
      exit 1
    fi
    printf '%s\n' "${names[@]}"
    return
  fi

  if [[ -n "$PACK" ]]; then
    require_pack "$PACK"
    printf '%s\n' "$PACK"
    return
  fi

  while IFS= read -r name; do
    names+=("$name")
  done < <(pack_names)

  if [[ "${#names[@]}" -eq 0 ]]; then
    echo "No portable baseline packs found in: $BASELINES_DIR" >&2
    exit 1
  fi
  if [[ "${#names[@]}" -eq 1 ]]; then
    printf '%s\n' "${names[0]}"
    return
  fi

  echo "Multiple portable baseline packs are available: ${names[*]}. Pass --pack <name>." >&2
  exit 1
}

json_field() {
  local pack="$1"
  local field="$2"
  sed -nE "s/^[[:space:]]*\"$field\"[[:space:]]*:[[:space:]]*\"([^\"]*)\".*/\1/p" "$(pack_root "$pack")/pack.json" | head -n 1
}

tool_target() {
  case "$1" in
    codex) printf 'AGENTS.md|AGENTS.md.block' ;;
    claude) printf 'CLAUDE.md|CLAUDE.md.block' ;;
    copilot) printf '.github/copilot-instructions.md|copilot-instructions.md.block' ;;
    *)
      echo "Unsupported tool '$1'. Supported tools: codex, claude, copilot, all" >&2
      exit 1
      ;;
  esac
}

tool_instruction_file() {
  case "$1" in
    claude) printf 'CLAUDE.md' ;;
    codex) printf 'AGENTS.md' ;;
    copilot) printf '.github/copilot-instructions.md' ;;
    *)
      echo "Unsupported tool '$1'. Supported tools: codex, claude, copilot, all" >&2
      exit 1
      ;;
  esac
}

normalized_tools() {
  local values="$1"
  local emitted=""
  local tool
  IFS=',' read -r -a tool_list <<< "$values"
  for tool in "${tool_list[@]}"; do
    tool="${tool//[[:space:]]/}"
    [[ -z "$tool" ]] && continue
    if [[ "$tool" == "all" ]]; then
      for all_tool in codex claude copilot; do
        if [[ ",$emitted," != *",$all_tool,"* ]]; then
          emitted="${emitted:+$emitted,}$all_tool"
          printf '%s\n' "$all_tool"
        fi
      done
      continue
    fi
    tool_target "$tool" >/dev/null
    if [[ ",$emitted," != *",$tool,"* ]]; then
      emitted="${emitted:+$emitted,}$tool"
      printf '%s\n' "$tool"
    fi
  done
}

list_tools() {
  if [[ "$TOOLS_PROVIDED" -eq 1 ]]; then
    normalized_tools "$TOOLS"
  else
    printf '%s\n' claude codex copilot
  fi
}

baseline_installed() {
  local pack="$1"
  local tool="$2"
  local target_rel target_path
  target_rel="$(tool_instruction_file "$tool")"
  target_path="$TARGET_REPO/$target_rel"
  [[ -f "$target_path" ]] || return 1
  grep -q "<!-- BEGIN baseline:$pack v" "$target_path" && return 0
  grep -q "<!-- BEGIN portable-agent-baseline:$pack v" "$target_path" && return 0
  return 1
}

status_cell() {
  local tool="$1"
  local installed="$2"
  local marker=" "
  [[ "$installed" == "1" ]] && marker="+"
  printf '[%s %s]' "$tool" "$marker"
}

verify_pack_shape() {
  local pack="$1"
  require_pack "$pack"
  local required=(
    "pack.json"
    "baseline.md"
    "adapters/AGENTS.md.block"
    "adapters/CLAUDE.md.block"
    "adapters/copilot-instructions.md.block"
  )
  local rel
  for rel in "${required[@]}"; do
    if [[ ! -f "$(pack_root "$pack")/$rel" ]]; then
      echo "Missing portable baseline file: $rel" >&2
      exit 1
    fi
  done
  local adapter
  for adapter in "$(pack_root "$pack")"/adapters/*.block; do
    if ! grep -q "<!-- BEGIN baseline:$pack v" "$adapter"; then
      echo "Adapter missing BEGIN marker: $adapter" >&2
      exit 1
    fi
    if ! grep -q "<!-- END baseline:$pack -->" "$adapter"; then
      echo "Adapter missing END marker: $adapter" >&2
      exit 1
    fi
  done
  echo "pack ok: $pack"
}

apply_tool() {
  local pack="$1"
  local tool="$2"
  local mapping target_rel adapter_rel target_path adapter_path action marker
  mapping="$(tool_target "$tool")"
  target_rel="${mapping%%|*}"
  adapter_rel="${mapping#*|}"
  target_path="$TARGET_REPO/$target_rel"
  adapter_path="$(pack_root "$pack")/adapters/$adapter_rel"

  if [[ ! -f "$target_path" ]]; then
    if [[ "$CREATE_MISSING" -ne 1 ]]; then
      echo "skip missing $target_rel for $tool in $TARGET_REPO"
      return
    fi
    if [[ "$DRY_RUN" -eq 1 ]]; then
      echo "would create $target_rel with $pack for $tool"
      return
    fi
    mkdir -p "$(dirname "$target_path")"
    cp "$adapter_path" "$target_path"
    printf '\n' >> "$target_path"
    echo "created $target_rel with $pack for $tool"
    return
  fi

  local has_new=0
  local has_legacy=0
  grep -q "<!-- BEGIN baseline:$pack v" "$target_path" && has_new=1
  grep -q "<!-- BEGIN portable-agent-baseline:$pack v" "$target_path" && has_legacy=1

  if [[ "$has_new" -eq 1 && "$has_legacy" -eq 1 ]]; then
    echo "Both baseline and legacy portable-agent-baseline blocks exist for $pack in $target_rel; resolve the duplicate manually." >&2
    exit 1
  fi

  if [[ "$has_new" -eq 1 || "$has_legacy" -eq 1 ]]; then
    action="update"
    marker="baseline"
    if [[ "$has_legacy" -eq 1 ]]; then
      action="migrate"
      marker="portable-agent-baseline"
    fi
    if [[ "$DRY_RUN" -ne 1 ]]; then
      PACK="$pack" MARKER="$marker" BLOCK_FILE="$adapter_path" perl -0pi -e 'BEGIN { $pack=$ENV{"PACK"}; $marker=$ENV{"MARKER"}; $block_file=$ENV{"BLOCK_FILE"}; open my $fh, "<", $block_file or die $!; local $/; $block=<$fh>; chomp $block; } $pattern=qr/<!-- BEGIN \Q$marker\E:\Q$pack\E v[^>]+ -->.*?<!-- END \Q$marker\E:\Q$pack\E -->/s; s/$pattern/$block/s;' "$target_path"
    fi
  else
    action="add"
    if [[ "$DRY_RUN" -ne 1 ]]; then
      {
        printf '\n\n'
        cat "$adapter_path"
        printf '\n'
      } >> "$target_path"
    fi
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "would $action $pack in $target_rel for $tool"
  elif [[ "$action" == "migrate" ]]; then
    echo "migrated $pack in $target_rel for $tool"
  elif [[ "$action" == "update" ]]; then
    echo "updated $pack in $target_rel for $tool"
  else
    echo "added $pack in $target_rel for $tool"
  fi
}

remove_tool() {
  local pack="$1"
  local tool="$2"
  local mapping target_rel target_path marker
  mapping="$(tool_target "$tool")"
  target_rel="${mapping%%|*}"
  target_path="$TARGET_REPO/$target_rel"

  if [[ ! -f "$target_path" ]]; then
    echo "skip missing $target_rel for $tool in $TARGET_REPO"
    return
  fi

  local has_new=0
  local has_legacy=0
  grep -q "<!-- BEGIN baseline:$pack v" "$target_path" && has_new=1
  grep -q "<!-- BEGIN portable-agent-baseline:$pack v" "$target_path" && has_legacy=1

  if [[ "$has_new" -eq 1 && "$has_legacy" -eq 1 ]]; then
    echo "Both baseline and legacy portable-agent-baseline blocks exist for $pack in $target_rel; resolve the duplicate manually." >&2
    exit 1
  fi

  if [[ "$has_new" -ne 1 && "$has_legacy" -ne 1 ]]; then
    echo "skip absent $pack in $target_rel for $tool"
    return
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "would remove $pack from $target_rel for $tool"
    return
  fi

  marker="baseline"
  [[ "$has_legacy" -eq 1 ]] && marker="portable-agent-baseline"
  PACK="$pack" MARKER="$marker" perl -0pi -e 'BEGIN { $pack=$ENV{"PACK"}; $marker=$ENV{"MARKER"}; } $pattern=qr/\r?\n?\r?\n?<!-- BEGIN \Q$marker\E:\Q$pack\E v[^>]+ -->.*?<!-- END \Q$marker\E:\Q$pack\E -->\r?\n?/s; s/$pattern/\n/s;' "$target_path"
  echo "removed $pack from $target_rel for $tool"
}

verify_tool() {
  local pack="$1"
  local tool="$2"
  local mapping target_rel target_path pack_version installed_version marker_status block_line
  mapping="$(tool_target "$tool")"
  target_rel="${mapping%%|*}"
  target_path="$TARGET_REPO/$target_rel"
  pack_version="$(json_field "$pack" version)"

  if [[ ! -f "$target_path" ]]; then
    echo "skip missing $target_rel for $tool in $TARGET_REPO"
    return
  fi

  local has_new=0
  local has_legacy=0
  grep -q "<!-- BEGIN baseline:$pack v" "$target_path" && has_new=1
  grep -q "<!-- BEGIN portable-agent-baseline:$pack v" "$target_path" && has_legacy=1

  if [[ "$has_new" -eq 1 && "$has_legacy" -eq 1 ]]; then
    echo "Both baseline and legacy portable-agent-baseline blocks exist for $pack in $target_rel" >&2
    exit 1
  fi

  if [[ "$has_new" -ne 1 && "$has_legacy" -ne 1 ]]; then
    echo "Missing $pack managed block in $target_rel" >&2
    exit 1
  fi

  if [[ "$has_legacy" -eq 1 ]]; then
    block_line="$(grep -m1 "<!-- BEGIN portable-agent-baseline:$pack v" "$target_path")"
    marker_status="legacy marker; run apply to migrate"
  else
    block_line="$(grep -m1 "<!-- BEGIN baseline:$pack v" "$target_path")"
    marker_status="marker ok"
  fi
  installed_version="$(printf '%s\n' "$block_line" | sed -nE 's/.* v([^ >]+) -->.*/\1/p')"
  if [[ "$installed_version" != "$pack_version" ]]; then
    echo "Stale $pack managed block in ${target_rel}: installed v$installed_version, source v$pack_version" >&2
    exit 1
  fi

  echo "target ok: $target_rel contains $pack v$installed_version ($marker_status)"
}

run_target_tools() {
  local pack="$1"
  local callback="$2"
  local tool
  while IFS= read -r tool; do
    "$callback" "$pack" "$tool"
  done < <(normalized_tools "$TOOLS")
}

case "$COMMAND" in
  list)
    TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"
    echo "Available packs  (target: $TARGET_REPO)"
    echo
    pack_names | while read -r pack_name; do
      cells=()
      while IFS= read -r tool; do
        if baseline_installed "$pack_name" "$tool"; then
          cells+=("$(status_cell "$tool" 1)")
        else
          cells+=("$(status_cell "$tool" 0)")
        fi
      done < <(list_tools)
      printf '%-40s v%-8s %s\n' "$(json_field "$pack_name" name)" "$(json_field "$pack_name" version)" "${cells[*]}"
    done
    echo
    echo "Legend: [+ applied]  [ absent]"
    ;;
  show)
    while IFS= read -r pack_name; do
      echo "# $(json_field "$pack_name" name) $(json_field "$pack_name" version) [$(json_field "$pack_name" status)]"
      echo
      echo "$(json_field "$pack_name" description)"
      echo
      echo "Adapters:"
      sed -nE 's/^[[:space:]]*"([^"]+)"[[:space:]]*:[[:space:]]*"([^"]+\.block)".*/- \1: \2/p' "$(pack_root "$pack_name")/pack.json"
      echo
      sed -n '1,$p' "$(pack_root "$pack_name")/baseline.md"
      echo
    done < <(resolve_packs)
    ;;
  apply)
    TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"
    while IFS= read -r pack_name; do
      verify_pack_shape "$pack_name" >/dev/null
      run_target_tools "$pack_name" apply_tool
    done < <(resolve_packs)
    ;;
  remove)
    TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"
    while IFS= read -r pack_name; do
      run_target_tools "$pack_name" remove_tool
    done < <(resolve_packs)
    ;;
  verify)
    current_dir="$(pwd -P)"
    verify_target=1
    if [[ "$TARGET_REPO_PROVIDED" -eq 0 && "$current_dir" == "$ROOT_DIR" ]]; then
      verify_target=0
    else
      TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"
    fi
    while IFS= read -r pack_name; do
      verify_pack_shape "$pack_name"
      if [[ "$verify_target" -eq 1 ]]; then
        run_target_tools "$pack_name" verify_tool
      fi
    done < <(resolve_packs)
    ;;
  --help|-h|help)
    usage
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    usage >&2
    exit 2
    ;;
esac
