#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
BASELINES_DIR="$ROOT_DIR/baselines"
COMMAND_NAME="${BASELINE_COMMAND_NAME:-baseline}"

COMMAND="${1:-list}"
if [[ $# -gt 0 ]]; then
  shift
fi

PACK=""
TARGET_REPO="$(pwd -P)"
TOOLS="codex,claude"
DRY_RUN=0
CREATE_MISSING=0

usage() {
  cat <<USAGE
Usage:
  $COMMAND_NAME list
  $COMMAND_NAME show [--pack <pack>]
  $COMMAND_NAME apply [--pack <pack>] --tools codex,claude,copilot [--target-repo <path>] [--dry-run] [--create-missing]
  $COMMAND_NAME remove [--pack <pack>] --tools codex,claude,copilot [--target-repo <path>] [--dry-run]
  $COMMAND_NAME verify [--pack <pack>] --tools codex,claude,copilot [--target-repo <path>]

When exactly one pack exists, --pack may be omitted. When multiple packs exist,
show/apply/remove/verify require --pack.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pack|-Pack)
      PACK="$2"
      shift 2
      ;;
    --target-repo|-TargetRepo)
      TARGET_REPO="$2"
      shift 2
      ;;
    --tools|-Tools)
      TOOLS="$2"
      shift 2
      ;;
    --dry-run|-DryRun)
      DRY_RUN=1
      shift
      ;;
    --create-missing|-CreateMissing)
      CREATE_MISSING=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

pack_root() {
  printf '%s/%s' "$BASELINES_DIR" "$PACK"
}

pack_names() {
  find "$BASELINES_DIR" -mindepth 1 -maxdepth 1 -type d | sort | while read -r dir; do
    [[ -f "$dir/pack.json" ]] || continue
    basename "$dir"
  done
}

require_pack() {
  if [[ ! -f "$(pack_root)/pack.json" ]]; then
    echo "Unknown portable baseline pack: $PACK" >&2
    exit 1
  fi
}

resolve_pack() {
  if [[ -n "$PACK" ]]; then
    require_pack
    return
  fi

  local names=()
  local name
  while IFS= read -r name; do
    names+=("$name")
  done < <(pack_names)

  if [[ "${#names[@]}" -eq 0 ]]; then
    echo "No portable baseline packs found in: $BASELINES_DIR" >&2
    exit 1
  fi
  if [[ "${#names[@]}" -eq 1 ]]; then
    PACK="${names[0]}"
    return
  fi

  echo "Multiple portable baseline packs are available: ${names[*]}. Pass --pack <name>." >&2
  exit 1
}

json_field() {
  local field="$1"
  sed -nE "s/^[[:space:]]*\"$field\"[[:space:]]*:[[:space:]]*\"([^\"]*)\".*/\1/p" "$(pack_root)/pack.json" | head -n 1
}

tool_target() {
  case "$1" in
    codex) printf 'AGENTS.md|AGENTS.md.block' ;;
    claude) printf 'CLAUDE.md|CLAUDE.md.block' ;;
    copilot) printf '.github/copilot-instructions.md|copilot-instructions.md.block' ;;
    *)
      echo "Unsupported tool '$1'. Supported tools: codex, claude, copilot" >&2
      exit 1
      ;;
  esac
}

verify_pack_shape() {
  require_pack
  local required=(
    "pack.json"
    "baseline.md"
    "adapters/AGENTS.md.block"
    "adapters/CLAUDE.md.block"
    "adapters/copilot-instructions.md.block"
  )
  local rel
  for rel in "${required[@]}"; do
    if [[ ! -f "$(pack_root)/$rel" ]]; then
      echo "Missing portable baseline file: $rel" >&2
      exit 1
    fi
  done
  local adapter
  for adapter in "$(pack_root)"/adapters/*.block; do
    if ! grep -q "<!-- BEGIN baseline:$PACK v" "$adapter"; then
      echo "Adapter missing BEGIN marker: $adapter" >&2
      exit 1
    fi
    if ! grep -q "<!-- END baseline:$PACK -->" "$adapter"; then
      echo "Adapter missing END marker: $adapter" >&2
      exit 1
    fi
  done
  echo "pack ok: $PACK"
}

for_each_tool() {
  local callback="$1"
  local tool
  IFS=',' read -r -a tool_list <<< "$TOOLS"
  for tool in "${tool_list[@]}"; do
    tool="${tool//[[:space:]]/}"
    [[ -z "$tool" ]] && continue
    "$callback" "$tool"
  done
}

apply_tool() {
  local tool="$1"
  local mapping target_rel adapter_rel target_path adapter_path action
  mapping="$(tool_target "$tool")"
  target_rel="${mapping%%|*}"
  adapter_rel="${mapping#*|}"
  target_path="$TARGET_REPO/$target_rel"
  adapter_path="$(pack_root)/adapters/$adapter_rel"

  if [[ ! -f "$target_path" ]]; then
    if [[ "$CREATE_MISSING" -ne 1 ]]; then
      echo "skip missing $target_rel for $tool in $TARGET_REPO"
      return
    fi
    if [[ "$DRY_RUN" -eq 1 ]]; then
      echo "would create $target_rel with $PACK for $tool"
      return
    fi
    mkdir -p "$(dirname "$target_path")"
    cp "$adapter_path" "$target_path"
    printf '\n' >> "$target_path"
    echo "created $target_rel with $PACK for $tool"
    return
  fi

  local has_new=0
  local has_legacy=0
  grep -q "<!-- BEGIN baseline:$PACK v" "$target_path" && has_new=1
  grep -q "<!-- BEGIN portable-agent-baseline:$PACK v" "$target_path" && has_legacy=1

  if [[ "$has_new" -eq 1 && "$has_legacy" -eq 1 ]]; then
    echo "Both baseline and legacy portable-agent-baseline blocks exist for $PACK in $target_rel; resolve the duplicate manually." >&2
    exit 1
  fi

  if [[ "$has_new" -eq 1 || "$has_legacy" -eq 1 ]]; then
    action="update"
    [[ "$has_legacy" -eq 1 ]] && action="migrate"
    if [[ "$DRY_RUN" -ne 1 ]]; then
      local marker="baseline"
      [[ "$has_legacy" -eq 1 ]] && marker="portable-agent-baseline"
      PACK="$PACK" MARKER="$marker" BLOCK_FILE="$adapter_path" perl -0pi -e 'BEGIN { $pack=$ENV{"PACK"}; $marker=$ENV{"MARKER"}; $block_file=$ENV{"BLOCK_FILE"}; open my $fh, "<", $block_file or die $!; local $/; $block=<$fh>; chomp $block; } $pattern=qr/<!-- BEGIN \Q$marker\E:\Q$pack\E v[^>]+ -->.*?<!-- END \Q$marker\E:\Q$pack\E -->/s; s/$pattern/$block/s;' "$target_path"
    fi
  else
    action="add"
    if [[ "$DRY_RUN" -ne 1 ]]; then
      {
        printf '\n\n'
        cat "$adapter_path"
        printf '\n'
      } >> "$target_path"
    fi
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "would $action $PACK in $target_rel for $tool"
  elif [[ "$action" == "migrate" ]]; then
    echo "migrated $PACK in $target_rel for $tool"
  elif [[ "$action" == "update" ]]; then
    echo "updated $PACK in $target_rel for $tool"
  else
    echo "added $PACK in $target_rel for $tool"
  fi
}

remove_tool() {
  local tool="$1"
  local mapping target_rel target_path
  mapping="$(tool_target "$tool")"
  target_rel="${mapping%%|*}"
  target_path="$TARGET_REPO/$target_rel"

  if [[ ! -f "$target_path" ]]; then
    echo "skip missing $target_rel for $tool in $TARGET_REPO"
    return
  fi
  local has_new=0
  local has_legacy=0
  grep -q "<!-- BEGIN baseline:$PACK v" "$target_path" && has_new=1
  grep -q "<!-- BEGIN portable-agent-baseline:$PACK v" "$target_path" && has_legacy=1

  if [[ "$has_new" -eq 1 && "$has_legacy" -eq 1 ]]; then
    echo "Both baseline and legacy portable-agent-baseline blocks exist for $PACK in $target_rel; resolve the duplicate manually." >&2
    exit 1
  fi

  if [[ "$has_new" -ne 1 && "$has_legacy" -ne 1 ]]; then
    echo "skip absent $PACK in $target_rel for $tool"
    return
  fi
  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "would remove $PACK from $target_rel for $tool"
    return
  fi

  local marker="baseline"
  [[ "$has_legacy" -eq 1 ]] && marker="portable-agent-baseline"
  PACK="$PACK" MARKER="$marker" perl -0pi -e 'BEGIN { $pack=$ENV{"PACK"}; $marker=$ENV{"MARKER"}; } $pattern=qr/\r?\n?\r?\n?<!-- BEGIN \Q$marker\E:\Q$pack\E v[^>]+ -->.*?<!-- END \Q$marker\E:\Q$pack\E -->\r?\n?/s; s/$pattern/\n/s;' "$target_path"
  echo "removed $PACK from $target_rel for $tool"
}

verify_tool() {
  local tool="$1"
  local mapping target_rel target_path
  mapping="$(tool_target "$tool")"
  target_rel="${mapping%%|*}"
  target_path="$TARGET_REPO/$target_rel"

  if [[ ! -f "$target_path" ]]; then
    echo "skip missing $target_rel for $tool in $TARGET_REPO"
    return
  fi
  local has_new=0
  local has_legacy=0
  grep -q "<!-- BEGIN baseline:$PACK v" "$target_path" && has_new=1
  grep -q "<!-- BEGIN portable-agent-baseline:$PACK v" "$target_path" && has_legacy=1

  if [[ "$has_new" -eq 1 && "$has_legacy" -eq 1 ]]; then
    echo "Both baseline and legacy portable-agent-baseline blocks exist for $PACK in $target_rel" >&2
    exit 1
  fi

  if [[ "$has_new" -ne 1 && "$has_legacy" -ne 1 ]]; then
    echo "Missing $PACK managed block in $target_rel" >&2
    exit 1
  fi
  if [[ "$has_legacy" -eq 1 ]]; then
    echo "target ok: $target_rel contains legacy $PACK marker (run apply to migrate)"
  else
    echo "target ok: $target_rel contains $PACK"
  fi
}

case "$COMMAND" in
  list)
    pack_names | while read -r pack_name; do
      PACK="$pack_name"
      echo "$(json_field name) $(json_field version) [$(json_field status)] - $(json_field description)"
    done
    ;;
  show)
    resolve_pack
    echo "# $(json_field name) $(json_field version) [$(json_field status)]"
    echo
    echo "$(json_field description)"
    echo
    echo "Adapters:"
    sed -nE 's/^[[:space:]]*"([^"]+)"[[:space:]]*:[[:space:]]*"([^"]+\.block)".*/- \1: \2/p' "$(pack_root)/pack.json"
    echo
    sed -n '1,$p' "$(pack_root)/baseline.md"
    ;;
  apply)
    resolve_pack
    verify_pack_shape >/dev/null
    TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"
    for_each_tool apply_tool
    ;;
  remove)
    resolve_pack
    TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"
    for_each_tool remove_tool
    ;;
  verify)
    resolve_pack
    verify_pack_shape
    TARGET_REPO="$(cd "$TARGET_REPO" && pwd -P)"
    for_each_tool verify_tool
    ;;
  --help|-h|help)
    usage
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    usage >&2
    exit 2
    ;;
esac
